@page "/dashboard/executions"
@using JobOrchestrator.Core.DTOs
@using JobOrchestrator.Core.Services
@rendermode InteractiveServer
@inject IJobService JobService

<PageTitle>Execution History</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0">Execution History</h4>
    <button class="btn btn-outline-secondary btn-sm" @onclick="LoadData">
        <i class="bi bi-arrow-clockwise me-1"></i>Refresh
    </button>
</div>

@if (rows == null)
{
    <div class="d-flex align-items-center gap-2 text-muted">
        <div class="spinner-border spinner-border-sm"></div>
        <span>Loading...</span>
    </div>
}
else if (!rows.Any())
{
    <div class="card border-0 shadow-sm">
        <div class="card-body text-center py-5 text-muted">
            <i class="bi bi-clock-history fs-1 mb-3 d-block"></i>
            <p>No executions recorded yet.</p>
        </div>
    </div>
}
else
{
    <div class="row g-2 mb-3">
        <div class="col-auto">
            <select class="form-select form-select-sm" @bind="statusFilter">
                <option value="">All Statuses</option>
                <option value="Completed">Completed</option>
                <option value="Failed">Failed</option>
                <option value="Retrying">Retrying</option>
                <option value="Running">Running</option>
            </select>
        </div>
        <div class="col-auto">
            <select class="form-select form-select-sm" @bind="jobFilter">
                <option value="">All Jobs</option>
                @foreach (var name in jobNames)
                {
                    <option value="@name">@name</option>
                }
            </select>
        </div>
        <div class="col-auto ms-auto text-muted small align-self-center">
            Showing @Filtered.Count() of @rows.Count executions
        </div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Job</th>
                        <th>Handler</th>
                        <th>Start Time</th>
                        <th>End Time</th>
                        <th>Duration</th>
                        <th>Attempt</th>
                        <th>Status</th>
                        <th>Error</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in Filtered.Take(200))
                    {
                        <tr>
                            <td class="fw-medium">@row.JobName</td>
                            <td><span class="badge bg-light text-dark">@row.HandlerName</span></td>
                            <td class="small">@row.Exec.StartTime.ToString("g")</td>
                            <td class="small text-muted">@(row.Exec.EndTime?.ToString("g") ?? "—")</td>
                            <td class="small text-muted">
                                @if (row.Exec.EndTime.HasValue)
                                {
                                    var dur = row.Exec.EndTime.Value - row.Exec.StartTime;
                                    @(dur.TotalSeconds < 60
                                        ? $"{dur.TotalSeconds:F1}s"
                                        : $"{dur.TotalMinutes:F1}m")
                                }
                                else { <span>—</span> }
                            </td>
                            <td class="small text-center">@row.Exec.ExecutionAttempt</td>
                            <td><span class="badge bg-@GetStatusColor(row.Exec.Status)">@row.Exec.Status</span></td>
                            <td class="small text-danger text-truncate" style="max-width:200px" title="@row.Exec.ErrorMessage">
                                @row.Exec.ErrorMessage
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@code {
    private record Row(string JobName, string HandlerName, JobExecutionDto Exec);

    private List<Row>? rows;
    private IEnumerable<string> jobNames = [];
    private string statusFilter = "";
    private string jobFilter = "";

    private IEnumerable<Row> Filtered => (rows?
        .Where(r => string.IsNullOrEmpty(statusFilter) || r.Exec.Status == statusFilter)
        .Where(r => string.IsNullOrEmpty(jobFilter) || r.JobName == jobFilter)
        .OrderByDescending(r => r.Exec.StartTime))
        ?? Enumerable.Empty<Row>();

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData()
    {
        var jobs = await JobService.GetAllJobsAsync();
        rows = jobs
            .SelectMany(j => j.RecentExecutions.Select(e => new Row(j.Name, j.HandlerName, e)))
            .ToList();
        jobNames = rows.Select(r => r.JobName).Distinct().OrderBy(n => n);
    }

    private static string GetStatusColor(string status) => status switch
    {
        "Completed" => "success",
        "Failed"    => "danger",
        "Retrying"  => "warning",
        "Running"   => "info",
        _           => "secondary"
    };
}
